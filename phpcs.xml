<?xml version="1.0"?>
<ruleset name="Lumosphere">
    <description>Lumosphère PHP coding standard</description>
    <file>api</file>
    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>
    <rule ref="PSR12">
        <!-- Architecture procédurale sans autoloader : les modules DAL requièrent
             leurs dépendances (require_once) en tête tout en déclarant des fonctions.
             PSR1 SideEffects est incompatible avec ce pattern volontaire. -->
        <exclude name="PSR1.Files.SideEffects"/>
    </rule>
</ruleset>
